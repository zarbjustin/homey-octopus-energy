{
  "extends": "athom/homey-app",
  "ignorePatterns": ["test/", ".homeybuild/", "node_modules/", "*.js"],
  "rules": {
    "linebreak-style": "off",
    "camelcase": "off",
    "max-classes-per-file": "off",
    "import/prefer-default-export": "off",
    "import/no-unresolved": "off",
    "import/extensions": "off",
    "node/no-missing-import": "off"
  }
}
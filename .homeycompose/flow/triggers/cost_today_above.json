{
  "id": "cost_today_above",
  "title": {
    "en": "Today's cost rises above ..."
  },
  "titleFormatted": {
    "en": "Cost (24h) of [[device]] rises above £[[amount]]"
  },
  "hint": {
    "en": "Triggers when the last-24h energy cost exceeds your budget."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "capabilities=octopus_cost_today",
      "title": {
        "en": "Device"
      }
    },
    {
      "type": "number",
      "name": "amount",
      "min": 0,
      "max": 1000,
      "step": 0.5,
      "placeholder": {
        "en": "5"
      },
      "title": {
        "en": "Amount (£)"
      }
    }
  ],
  "tokens": [
    {
      "name": "cost",
      "type": "number",
      "title": {
        "en": "Cost (£)"
      },
      "example": 6.2
    }
  ]
}

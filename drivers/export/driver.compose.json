{
  "name": {
    "en": "Export Meter"
  },
  "class": "sensor",
  "capabilities": [
    "measure_octopus_price",
    "octopus_standing_charge",
    "octopus_usage_today",
    "meter_power.exported",
    "octopus_earnings_today",
    "octopus_earnings_month",
    "octopus_earnings_projected",
    "measure_octopus_balance",
    "octopus_updated",
    "alarm_generic"
  ],
  "capabilitiesOptions": {
    "meter_power.exported": {
      "title": {
        "en": "Total exported"
      }
    },
    "measure_octopus_price": {
      "title": {
        "en": "Export rate"
      }
    },
    "octopus_usage_today": {
      "title": {
        "en": "Exported (last 24h)"
      }
    },
    "alarm_generic": {
      "title": {
        "en": "Connection problem"
      }
    }
  },
  "energy": {
    "cumulative": true,
    "cumulativeExportedCapability": "meter_power.exported"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "images": {
    "small": "/drivers/export/assets/images/small.png",
    "large": "/drivers/export/assets/images/large.png",
    "xlarge": "/drivers/export/assets/images/xlarge.png"
  },
  "pair": [
    { "id": "start" },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    { "id": "add_devices", "template": "add_devices" }
  ],
  "repair": [
    { "id": "start" }
  ],
  "settings": [
    {
      "id": "poll_interval",
      "type": "number",
      "label": { "en": "Refresh interval (minutes)" },
      "value": 30,
      "min": 5,
      "max": 1440,
      "hint": { "en": "How often to refresh export prices, exported energy and balance." }
    },
    {
      "id": "vat",
      "type": "dropdown",
      "label": { "en": "Prices include VAT" },
      "value": "inc",
      "values": [
        { "id": "inc", "label": { "en": "Including VAT" } },
        { "id": "exc", "label": { "en": "Excluding VAT" } }
      ]
    }
  ]
}

{
  "triggers": [
    {
      "id": "target_rate_window_started",
      "title": {
        "en": "A target-rate window started ..."
      },
      "titleFormatted": {
        "en": "A cheapest [[duration]] h window under [[max_price]] p/kWh before [[by]] started"
      },
      "hint": {
        "en": "Fires when a cheap window (the cheapest half-hours up to your price cap before the deadline) begins. Forward prices are estimates; won't fire if the cap can't be met or rates aren't published yet."
      },
      "args": [
        {
          "type": "number",
          "name": "duration",
          "min": 0.5,
          "max": 12,
          "step": 0.5,
          "placeholder": { "en": "3" },
          "title": { "en": "Duration (hours)" }
        },
        {
          "type": "text",
          "name": "by",
          "placeholder": { "en": "07:00" },
          "title": { "en": "By time (HH:MM)" }
        },
        {
          "type": "number",
          "name": "max_price",
          "min": 0,
          "max": 200,
          "step": 0.5,
          "placeholder": { "en": "0 = no cap" },
          "title": { "en": "Max price (p/kWh, 0 = no cap)" }
        }
      ],
      "tokens": [
        {
          "name": "price",
          "type": "number",
          "title": { "en": "Current price (p/kWh)" },
          "example": 6.9
        }
      ]
    },
    {
      "id": "price_changed",
      "title": {
        "en": "The unit rate changed"
      },
      "hint": {
        "en": "Triggers each half hour when the electricity unit rate changes."
      },
      "tokens": [
        {
          "name": "price",
          "type": "number",
          "title": {
            "en": "Price (p/kWh)"
          },
          "example": 18.5
        },
        {
          "name": "previous",
          "type": "number",
          "title": {
            "en": "Previous price"
          },
          "example": 22.1
        }
      ]
    },
    {
      "id": "price_below",
      "title": {
        "en": "The price drops below ..."
      },
      "titleFormatted": {
        "en": "The unit rate drops below [[price]] p/kWh"
      },
      "hint": {
        "en": "Triggers when a new half-hourly unit rate is below your threshold."
      },
      "args": [
        {
          "type": "number",
          "name": "price",
          "min": -50,
          "max": 200,
          "step": 0.1,
          "placeholder": {
            "en": "15"
          },
          "title": {
            "en": "Price (p/kWh)"
          }
        }
      ],
      "tokens": [
        {
          "name": "price",
          "type": "number",
          "title": {
            "en": "Price (p/kWh)"
          },
          "example": 12.3
        }
      ]
    },
    {
      "id": "price_plunge",
      "title": {
        "en": "The price went negative"
      },
      "hint": {
        "en": "Triggers when the unit rate drops below zero — Octopus is paying you to use energy."
      },
      "tokens": [
        {
          "name": "price",
          "type": "number",
          "title": {
            "en": "Price (p/kWh)"
          },
          "example": -2.5
        }
      ]
    },
    {
      "id": "price_level_changed",
      "title": {
        "en": "The price level changed"
      },
      "hint": {
        "en": "Triggers when the price level changes between plunge, cheap, normal and expensive."

          "type": "number",
          "name": "threshold",
          "min": 0,
          "max": 600,
          "step": 5,
          "placeholder": {
            "en": "100"
          },
          "title": {
            "en": "Carbon intensity (gCO₂/kWh)"
          }
        }
      ],
      "tokens": [
        {
          "name": "carbon",
          "type": "number",
          "title": {
            "en": "Carbon (gCO₂/kWh)"
          },
          "example": 85
        }

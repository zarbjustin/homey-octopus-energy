          "name": "most_expensive",
          "type": "number",
          "title": {
            "en": "Most expensive upcoming (p/kWh)"
          },
          "example": 34
        }
      ]
    },
    {
      "id": "night_rate_started",
      "title": {
        "en": "The Economy 7 night rate started"

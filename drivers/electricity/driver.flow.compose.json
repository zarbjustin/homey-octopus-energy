{
  "triggers": [
    {
      "id": "price_changed",
      "title": { "en": "The unit rate changed" },
      "hint": { "en": "Triggers each half hour when the electricity unit rate changes." },
      "tokens": [
        { "name": "price", "type": "number", "title": { "en": "Price (p/kWh)" }, "example": 18.5 },
        { "name": "previous", "type": "number", "title": { "en": "Previous price" }, "example": 22.1 }
      ]
    },
    {
      "id": "price_below",
      "title": { "en": "The price drops below ..." },
      "titleFormatted": { "en": "The unit rate drops below [[price]] p/kWh" },
      "hint": { "en": "Triggers when a new half-hourly unit rate is below your threshold." },
      "args": [
        {
          "type": "number",
          "name": "price",
          "min": -50,
          "max": 200,
          "step": 0.1,
          "placeholder": { "en": "15" }
        }
      ],
      "tokens": [
        { "name": "price", "type": "number", "title": { "en": "Price (p/kWh)" }, "example": 12.3 }
      ]
    },
    {
      "id": "price_plunge",
      "title": { "en": "The price went negative (plunge)" },
      "hint": { "en": "Triggers when the unit rate drops below zero — Octopus is paying you to use energy." },
      "tokens": [
        { "name": "price", "type": "number", "title": { "en": "Price (p/kWh)" }, "example": -2.5 }
      ]
    },
    {
      "id": "price_level_changed",
      "title": { "en": "The price level changed" },
      "hint": { "en": "Triggers when the price level changes between plunge, cheap, normal and expensive." },
      "tokens": [
        { "name": "level", "type": "string", "title": { "en": "Level" }, "example": { "en": "cheap" } },
        { "name": "previous", "type": "string", "title": { "en": "Previous level" }, "example": { "en": "normal" } }
      ]
    },
    {
      "id": "cheapest_slot_started",
      "title": { "en": "The cheapest half-hour started" },
      "titleFormatted": { "en": "Now is the cheapest half-hour in the next [[hours]] h" },
      "hint": { "en": "Triggers when the current half-hour is the cheapest within the look-ahead window." },
      "args": [
        {
          "type": "number",
          "name": "hours",
          "min": 1,
          "max": 48,
          "step": 1,
          "placeholder": { "en": "12" }
        }
      ],
      "tokens": [
        { "name": "price", "type": "number", "title": { "en": "Price (p/kWh)" }, "example": 9.8 }
      ]
    },
    {
      "id": "smart_charge_started",
      "title": { "en": "The smart charge window started" },
      "hint": { "en": "Triggers when the current half-hour enters your cheapest smart-charge plan." }
    },
    {
      "id": "smart_charge_ended",
      "title": { "en": "The smart charge window ended" },
      "hint": { "en": "Triggers when the current half-hour leaves your cheapest smart-charge plan." }
    }
  ],
  "conditions": [
    {
      "id": "price_below_now",
      "title": { "en": "Current price !{{is below|is not below}} ..." },
      "titleFormatted": { "en": "Current price !{{is below|is not below}} [[price]] p/kWh" },
      "args": [
        {
          "type": "number",
          "name": "price",
          "min": -50,
          "max": 200,
          "step": 0.1,
          "placeholder": { "en": "15" }
        }
      ]
    },
    {
      "id": "is_cheapest_now",
      "title": { "en": "Now !{{is|is not}} the cheapest half-hour" },
      "titleFormatted": { "en": "Now !{{is|is not}} the cheapest half-hour in the next [[hours]] h" },
      "args": [
        {
          "type": "number",
          "name": "hours",
          "min": 1,
          "max": 48,
          "step": 1,
          "placeholder": { "en": "12" }
        }
      ]
    },
    {
      "id": "price_level_is",
      "title": { "en": "The price level !{{is|is not}} ..." },
      "titleFormatted": { "en": "The price level !{{is|is not}} [[level]]" },
      "args": [
        {
          "type": "dropdown",
          "name": "level",
          "values": [
            { "id": "plunge", "label": { "en": "Plunge (negative)" } },
            { "id": "cheap", "label": { "en": "Cheap" } },
            { "id": "normal", "label": { "en": "Normal" } },
            { "id": "expensive", "label": { "en": "Expensive" } }
          ]
        }
      ]
    },
    {
      "id": "within_cheapest_period",
      "title": { "en": "Now !{{is|is not}} within the cheapest period" },
      "titleFormatted": { "en": "Now !{{is|is not}} within the cheapest [[duration]] h block of the next [[within]] h" },
      "args": [
        {
          "type": "number",
          "name": "duration",
          "min": 0.5,
          "max": 12,
          "step": 0.5,
          "placeholder": { "en": "3" }
        },
        {
          "type": "number",
          "name": "within",
          "min": 1,
          "max": 48,
          "step": 1,
          "placeholder": { "en": "12" }
        }
      ]
    },
    {
      "id": "in_cheapest_plan",
      "title": { "en": "Now !{{is|is not}} in the cheapest charge plan" },
      "titleFormatted": { "en": "Now !{{is|is not}} in the cheapest [[duration]] h before [[by]]" },
      "args": [
        {
          "type": "number",
          "name": "duration",
          "min": 0.5,
          "max": 12,
          "step": 0.5,
          "placeholder": { "en": "3" }
        },
        {
          "type": "text",
          "name": "by",
          "placeholder": { "en": "07:00" }
        }
      ]
    },
    {
      "id": "carbon_below",
      "title": { "en": "Carbon intensity !{{is below|is not below}} ..." },
      "titleFormatted": { "en": "Carbon intensity !{{is below|is not below}} [[intensity]] gCO₂/kWh" },
      "args": [
        { "type": "number", "name": "intensity", "min": 0, "max": 600, "step": 5, "placeholder": { "en": "100" } }
      ]
    },
    {
      "id": "is_greenest_now",
      "title": { "en": "Now !{{is|is not}} the greenest half-hour" },
      "titleFormatted": { "en": "Now !{{is|is not}} the greenest half-hour in the next [[hours]] h" },
      "args": [
        { "type": "number", "name": "hours", "min": 1, "max": 48, "step": 1, "placeholder": { "en": "12" } }
      ]
    },
    {
      "id": "carbon_level_is",
      "title": { "en": "The carbon level !{{is|is not}} ..." },
      "titleFormatted": { "en": "The carbon level !{{is|is not}} [[level]]" },
      "args": [
        {
          "type": "dropdown",
          "name": "level",
          "values": [
            { "id": "very_low", "label": { "en": "Very low" } },
            { "id": "low", "label": { "en": "Low" } },
            { "id": "moderate", "label": { "en": "Moderate" } },
            { "id": "high", "label": { "en": "High" } },
            { "id": "very_high", "label": { "en": "Very high" } }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "refresh_now",
      "title": { "en": "Refresh Octopus data" },
      "hint": { "en": "Immediately refresh prices, usage and balance from Octopus Energy." }
    },
    {
      "id": "find_cheapest_slot",
      "title": { "en": "Find the cheapest upcoming slot" },
      "titleFormatted": { "en": "Find the cheapest [[duration]] h slot in the next [[within]] h" },
      "hint": { "en": "Returns the start time and average price of the cheapest block of half-hours ahead." },
      "args": [
        {
          "type": "number",
          "name": "duration",
          "min": 0.5,
          "max": 12,
          "step": 0.5,
          "placeholder": { "en": "3" }
        },
        {
          "type": "number",
          "name": "within",
          "min": 1,
          "max": 48,
          "step": 1,
          "placeholder": { "en": "12" }
        }
      ],
      "tokens": [
        { "name": "start_time", "type": "string", "title": { "en": "Start time" }, "example": { "en": "Mon 01:30" } },
        { "name": "price", "type": "number", "title": { "en": "Average price (p/kWh)" }, "example": 8.4 }
      ]
    },
    {
      "id": "find_cheapest_hours",
      "title": { "en": "Plan the cheapest hours before a time" },
      "titleFormatted": { "en": "Plan the cheapest [[duration]] h before [[by]]" },
      "hint": { "en": "Selects the cheapest (non-contiguous) half-hours between now and the given time." },
      "args": [
        {
          "type": "number",
          "name": "duration",
          "min": 0.5,
          "max": 12,
          "step": 0.5,
          "placeholder": { "en": "3" }
        },
        {
          "type": "text",
          "name": "by",
          "placeholder": { "en": "07:00" }
        }
      ],
      "tokens": [
        { "name": "count", "type": "number", "title": { "en": "Number of half-hours" }, "example": 6 },
        { "name": "first_start", "type": "string", "title": { "en": "First slot start" }, "example": { "en": "Tue 01:00" } },
        { "name": "price", "type": "number", "title": { "en": "Average price (p/kWh)" }, "example": 7.9 }
      ]
    }
  ]
}

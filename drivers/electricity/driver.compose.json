{
  "name": {
    "en": "Electricity Meter"
  },
  "class": "sensor",
  "capabilities": [
    "measure_octopus_price",
    "octopus_price_level",
    "octopus_price_next",
    "octopus_good_now",
    "octopus_smart_charge",
    "octopus_charge_start",
    "octopus_dispatching",
    "measure_octopus_carbon",
    "octopus_carbon_level",
    "measure_renewable_percent",
    "meter_power",
    "octopus_usage_today",
    "octopus_standing_charge",
    "octopus_cost_today",
    "octopus_cost_yesterday",
    "octopus_cost_peak_today",
    "octopus_cost_offpeak_today",
    "octopus_cost_month",
    "octopus_cost_projected",
    "octopus_price_min_today",
    "octopus_price_max_today",
    "octopus_price_avg_today",
    "measure_octopus_balance",
    "octopus_points",
    "octopus_updated",
    "alarm_generic"
  ],
  "capabilitiesOptions": {
    "meter_power": {
      "title": {
        "en": "Total consumption"
      }
    },
    "alarm_generic": {
      "title": {
        "en": "Connection problem"
      }
    }
  },
  "energy": {
    "cumulative": true,
    "cumulativeImportedCapability": "meter_power"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "images": {
    "small": "/drivers/electricity/assets/images/small.png",
    "large": "/drivers/electricity/assets/images/large.png",
    "xlarge": "/drivers/electricity/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "start"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "start"
    }
  ],
  "settings": [
    {
      "id": "poll_interval",
      "type": "number",
      "label": {
        "en": "Refresh interval (minutes)"
      },
      "value": 30,
      "min": 5,
      "max": 1440,
      "hint": {
        "en": "How often to refresh prices, usage and balance. Prices update once per half hour."
      }
    },
    {
      "id": "vat",
      "type": "dropdown",
      "label": {
        "en": "Prices include VAT"
      },
      "value": "inc",
      "hint": {
        "en": "Whether displayed unit rates and standing charges include 5% VAT."
      },
      "values": [
        { "id": "inc", "label": { "en": "Including VAT" } },
        { "id": "exc", "label": { "en": "Excluding VAT" } }
      ]
    },
    {
      "id": "cheap_threshold",
      "type": "number",
      "label": {
        "en": "\"Cheap\" price threshold (p/kWh)"
      },
      "value": 15,
      "min": -50,
      "max": 200,
      "hint": {
        "en": "At or below this unit rate the price level is considered cheap."
      }
    },
    {
      "id": "expensive_threshold",
      "type": "number",
      "label": {
        "en": "\"Expensive\" price threshold (p/kWh)"
      },
      "value": 30,
      "min": -50,
      "max": 200,
      "hint": {
        "en": "At or above this unit rate the price level is considered expensive."
      }
    },
    {
      "id": "live_power",
      "type": "checkbox",
      "label": {
        "en": "Live power (Octopus Home Mini)"
      },
      "value": false,
      "hint": {
        "en": "Off by default. Tick this if you have an Octopus Home Mini to show near real-time power (W); it adds a Power capability and polls every 30 seconds. Leave off if you have no Home Mini."
      }
    },
    {
      "id": "smart_charge_hours",
      "type": "number",
      "label": {
        "en": "Smart charge duration (hours)"
      },
      "value": 3,
      "min": 0.5,
      "max": 12,
      "step": 0.5,
      "hint": {
        "en": "How many hours of cheapest slots the 'Smart charge window' capability should select."
      }
    },
    {
      "id": "smart_charge_by",
      "type": "text",
      "label": {
        "en": "Smart charge by (HH:MM)"
      },
      "value": "07:00",
      "hint": {
        "en": "Find the cheapest slots between now and this time each day (24-hour clock)."
      }
    },
    {
      "id": "smart_charge_max_price",
      "type": "number",
      "label": {
        "en": "Smart charge price cap (p/kWh)"
      },
      "value": 0,
      "min": 0,
      "max": 200,
      "hint": {
        "en": "Only include slots at or below this price in the smart-charge window. 0 = no cap."
      }
    },
    {
      "id": "night_start",
      "type": "text",
      "label": {
        "en": "Economy 7 night start (HH:MM)"
      },
      "value": "00:30",
      "hint": {
        "en": "For Economy 7 meters: when the cheaper night rate begins (local time)."
      }
    },
    {
      "id": "night_end",
      "type": "text",
      "label": {
        "en": "Economy 7 night end (HH:MM)"
      },
      "value": "07:30",
      "hint": {
        "en": "For Economy 7 meters: when the night rate ends and the day rate resumes."
      }
    },
    {
      "id": "carbon_region",
      "type": "dropdown",
      "label": {
        "en": "Carbon intensity region"
      },
      "value": "auto",
      "hint": {
        "en": "Regional carbon uses your tariff's grid region (recommended). National averages the whole of GB."
      },
      "values": [
        { "id": "auto", "label": { "en": "Regional (from my tariff)" } },
        { "id": "national", "label": { "en": "National (GB average)" } }
      ]
    }
  ]
}

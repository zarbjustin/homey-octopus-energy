{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "uk.co.zarb.octopusenergy",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#FF1493",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Octopus Energy"
  },
  "description": {
    "en": "Monitor your Octopus Energy tariffs, prices, usage and balance.",
    "nl": "Volg je Octopus Energy-tarieven, prijzen, verbruik en saldo.",
    "de": "Überwache deine Octopus Energy-Tarife, Preise, Verbrauch und Guthaben.",
    "fr": "Suivez vos tarifs, prix, consommation et solde Octopus Energy."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Justin Zarb",
    "email": "justin.zarb@zarb.co.uk"
  },
  "flow": {
    "triggers": [
      {
        "id": "balance_below",
        "title": {
          "en": "The account balance drops below ..."
        },
        "titleFormatted": {
          "en": "The balance of [[device]] drops below £[[amount]]"
        },
        "hint": {
          "en": "Triggers when your Octopus account balance falls below the amount."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          },
          {
            "type": "number",
            "name": "amount",
            "min": -10000,
            "max": 10000,
            "step": 1,
            "placeholder": {
              "en": "0"
            }
          }
        ],
        "tokens": [
          {
            "name": "balance",
            "type": "number",
            "title": {
              "en": "Balance (£)"
            },
            "example": -5.2
          }
        ]
      },
      {
        "id": "balance_changed",
        "title": {
          "en": "The account balance changed"
        },
        "titleFormatted": {
          "en": "The balance of [[device]] changed"
        },
        "hint": {
          "en": "Triggers when your Octopus account balance changes."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          }
        ],
        "tokens": [
          {
            "name": "balance",
            "type": "number",
            "title": {
              "en": "Balance (£)"
            },
            "example": 124.5
          }
        ]
      },
      {
        "id": "dispatch_ended",
        "title": {
          "en": "A smart-charge dispatch ended"
        },
        "hint": {
          "en": "Triggers when an Intelligent Octopus Go smart-charge dispatch finishes."
        }
      },
      {
        "id": "dispatch_started",
        "title": {
          "en": "A smart-charge dispatch started"
        },
        "hint": {
          "en": "Triggers when Intelligent Octopus Go begins a planned smart-charge dispatch."
        },
        "tokens": [
          {
            "name": "end",
            "type": "string",
            "title": {
              "en": "Ends"
            },
            "example": {
              "en": "Tue 05:30"
            }
          }
        ]
      },
      {
        "id": "free_electricity_ended",
        "title": {
          "en": "A Free Electricity session ended"
        },
        "hint": {
          "en": "Triggers when an Octopus Free Electricity session finishes."
        }
      },
      {
        "id": "free_electricity_started",
        "title": {
          "en": "A Free Electricity session started"
        },
        "hint": {
          "en": "Triggers when an Octopus Free Electricity session begins — electricity is free now."
        },
        "tokens": [
          {
            "name": "end",
            "type": "string",
            "title": {
              "en": "Ends"
            },
            "example": {
              "en": "Sun 14:00"
            }
          }
        ]
      },
      {
        "id": "saving_session_announced",
        "title": {
          "en": "A Saving Session was announced"
        },
        "hint": {
          "en": "Triggers once when a new Octopus Saving Session appears for your account."
        },
        "tokens": [
          {
            "name": "start",
            "type": "string",
            "title": {
              "en": "Start"
            },
            "example": {
              "en": "Tue 17:00"
            }
          },
          {
            "name": "end",
            "type": "string",
            "title": {
              "en": "End"
            },
            "example": {
              "en": "Tue 18:00"
            }
          },
          {
            "name": "reward",
            "type": "number",
            "title": {
              "en": "OctoPoints per kWh"
            },
            "example": 1800
          }
        ]
      },
      {
        "id": "saving_session_ended",
        "title": {
          "en": "A Saving Session ended"
        },
        "hint": {
          "en": "Triggers when an Octopus Saving Session finishes."
        }
      },
      {
        "id": "saving_session_started",
        "title": {
          "en": "A Saving Session started"
        },
        "hint": {
          "en": "Triggers when an Octopus Saving Session begins — reduce usage to earn OctoPoints."
        },
        "tokens": [
          {
            "name": "end",
            "type": "string",
            "title": {
              "en": "End"
            },
            "example": {
              "en": "Tue 18:00"
            }
          },
          {
            "name": "reward",
            "type": "number",
            "title": {
              "en": "OctoPoints per kWh"
            },
            "example": 1800
          }
        ]
      },
      {
        "id": "saving_session_starting_soon",
        "title": {
          "en": "A Saving Session is starting soon"
        },
        "titleFormatted": {
          "en": "A Saving Session starts within [[lead]] minutes"
        },
        "hint": {
          "en": "Triggers when a Saving Session is due to start within the lead time you set."
        },
        "args": [
          {
            "type": "number",
            "name": "lead",
            "min": 5,
            "max": 240,
            "step": 5,
            "placeholder": {
              "en": "30"
            }
          }
        ],
        "tokens": [
          {
            "name": "start",
            "type": "string",
            "title": {
              "en": "Start"
            },
            "example": {
              "en": "Tue 17:00"
            }
          },
          {
            "name": "end",
            "type": "string",
            "title": {
              "en": "End"
            },
            "example": {
              "en": "Tue 18:00"
            }
          },
          {
            "name": "reward",
            "type": "number",
            "title": {
              "en": "OctoPoints per kWh"
            },
            "example": 1800
          }
        ]
      },
      {
        "id": "price_changed",
        "title": {
          "en": "The unit rate changed"
        },
        "hint": {
          "en": "Triggers each half hour when the electricity unit rate changes."
        },
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 18.5
          },
          {
            "name": "previous",
            "type": "number",
            "title": {
              "en": "Previous price"
            },
            "example": 22.1
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "price_below",
        "title": {
          "en": "The price drops below ..."
        },
        "titleFormatted": {
          "en": "The unit rate drops below [[price]] p/kWh"
        },
        "hint": {
          "en": "Triggers when a new half-hourly unit rate is below your threshold."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "price",
            "min": -50,
            "max": 200,
            "step": 0.1,
            "placeholder": {
              "en": "15"
            }
          }
        ],
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 12.3
          }
        ]
      },
      {
        "id": "price_plunge",
        "title": {
          "en": "The price went negative (plunge)"
        },
        "hint": {
          "en": "Triggers when the unit rate drops below zero — Octopus is paying you to use energy."
        },
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": -2.5
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "price_level_changed",
        "title": {
          "en": "The price level changed"
        },
        "hint": {
          "en": "Triggers when the price level changes between plunge, cheap, normal and expensive."
        },
        "tokens": [
          {
            "name": "level",
            "type": "string",
            "title": {
              "en": "Level"
            },
            "example": {
              "en": "cheap"
            }
          },
          {
            "name": "previous",
            "type": "string",
            "title": {
              "en": "Previous level"
            },
            "example": {
              "en": "normal"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "cheapest_slot_started",
        "title": {
          "en": "The cheapest half-hour started"
        },
        "titleFormatted": {
          "en": "Now is the cheapest half-hour in the next [[hours]] h"
        },
        "hint": {
          "en": "Triggers when the current half-hour is the cheapest within the look-ahead window."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "hours",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ],
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 9.8
          }
        ]
      },
      {
        "id": "smart_charge_started",
        "title": {
          "en": "The smart charge window started"
        },
        "hint": {
          "en": "Triggers when the current half-hour enters your cheapest smart-charge plan."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "smart_charge_ended",
        "title": {
          "en": "The smart charge window ended"
        },
        "hint": {
          "en": "Triggers when the current half-hour leaves your cheapest smart-charge plan."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "balance_below_now",
        "title": {
          "en": "The account balance !{{is below|is not below}} ..."
        },
        "titleFormatted": {
          "en": "The balance of [[device]] !{{is below|is not below}} £[[amount]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          },
          {
            "type": "number",
            "name": "amount",
            "min": -10000,
            "max": 10000,
            "step": 1,
            "placeholder": {
              "en": "0"
            }
          }
        ]
      },
      {
        "id": "dispatch_active",
        "title": {
          "en": "A smart-charge dispatch !{{is|is not}} active"
        },
        "hint": {
          "en": "Whether Intelligent Octopus Go is currently running a smart-charge dispatch."
        }
      },
      {
        "id": "price_below_now",
        "title": {
          "en": "Current price !{{is below|is not below}} ..."
        },
        "titleFormatted": {
          "en": "Current price !{{is below|is not below}} [[price]] p/kWh"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "price",
            "min": -50,
            "max": 200,
            "step": 0.1,
            "placeholder": {
              "en": "15"
            }
          }
        ]
      },
      {
        "id": "is_cheapest_now",
        "title": {
          "en": "Now !{{is|is not}} the cheapest half-hour"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} the cheapest half-hour in the next [[hours]] h"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "hours",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ]
      },
      {
        "id": "price_level_is",
        "title": {
          "en": "The price level !{{is|is not}} ..."
        },
        "titleFormatted": {
          "en": "The price level !{{is|is not}} [[level]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "dropdown",
            "name": "level",
            "values": [
              {
                "id": "plunge",
                "label": {
                  "en": "Plunge (negative)"
                }
              },
              {
                "id": "cheap",
                "label": {
                  "en": "Cheap"
                }
              },
              {
                "id": "normal",
                "label": {
                  "en": "Normal"
                }
              },
              {
                "id": "expensive",
                "label": {
                  "en": "Expensive"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "within_cheapest_period",
        "title": {
          "en": "Now !{{is|is not}} within the cheapest period"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} within the cheapest [[duration]] h block of the next [[within]] h"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "number",
            "name": "within",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ]
      },
      {
        "id": "in_cheapest_plan",
        "title": {
          "en": "Now !{{is|is not}} in the cheapest charge plan"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} in the cheapest [[duration]] h before [[by]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "text",
            "name": "by",
            "placeholder": {
              "en": "07:00"
            }
          }
        ]
      },
      {
        "id": "carbon_below",
        "title": {
          "en": "Carbon intensity !{{is below|is not below}} ..."
        },
        "titleFormatted": {
          "en": "Carbon intensity !{{is below|is not below}} [[intensity]] gCO₂/kWh"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "intensity",
            "min": 0,
            "max": 600,
            "step": 5,
            "placeholder": {
              "en": "100"
            }
          }
        ]
      },
      {
        "id": "is_greenest_now",
        "title": {
          "en": "Now !{{is|is not}} the greenest half-hour"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} the greenest half-hour in the next [[hours]] h"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "hours",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ]
      },
      {
        "id": "carbon_level_is",
        "title": {
          "en": "The carbon level !{{is|is not}} ..."
        },
        "titleFormatted": {
          "en": "The carbon level !{{is|is not}} [[level]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "dropdown",
            "name": "level",
            "values": [
              {
                "id": "very_low",
                "label": {
                  "en": "Very low"
                }
              },
              {
                "id": "low",
                "label": {
                  "en": "Low"
                }
              },
              {
                "id": "moderate",
                "label": {
                  "en": "Moderate"
                }
              },
              {
                "id": "high",
                "label": {
                  "en": "High"
                }
              },
              {
                "id": "very_high",
                "label": {
                  "en": "Very high"
                }
              }
            ]
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "refresh_now",
        "title": {
          "en": "Refresh Octopus data"
        },
        "hint": {
          "en": "Immediately refresh prices, usage and balance from Octopus Energy."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "find_cheapest_slot",
        "title": {
          "en": "Find the cheapest upcoming slot"
        },
        "titleFormatted": {
          "en": "Find the cheapest [[duration]] h slot in the next [[within]] h"
        },
        "hint": {
          "en": "Returns the start time and average price of the cheapest block of half-hours ahead."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "number",
            "name": "within",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ],
        "tokens": [
          {
            "name": "start_time",
            "type": "string",
            "title": {
              "en": "Start time"
            },
            "example": {
              "en": "Mon 01:30"
            }
          },
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Average price (p/kWh)"
            },
            "example": 8.4
          }
        ]
      },
      {
        "id": "find_cheapest_hours",
        "title": {
          "en": "Plan the cheapest hours before a time"
        },
        "titleFormatted": {
          "en": "Plan the cheapest [[duration]] h before [[by]]"
        },
        "hint": {
          "en": "Selects the cheapest (non-contiguous) half-hours between now and the given time."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "text",
            "name": "by",
            "placeholder": {
              "en": "07:00"
            }
          }
        ],
        "tokens": [
          {
            "name": "count",
            "type": "number",
            "title": {
              "en": "Number of half-hours"
            },
            "example": 6
          },
          {
            "name": "first_start",
            "type": "string",
            "title": {
              "en": "First slot start"
            },
            "example": {
              "en": "Tue 01:00"
            }
          },
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Average price (p/kWh)"
            },
            "example": 7.9
          }
        ]
      },
      {
        "id": "find_best_tariff",
        "title": {
          "en": "Compare my tariff"
        },
        "titleFormatted": {
          "en": "Compare my tariff over the last [[days]] days"
        },
        "hint": {
          "en": "Estimates the cheapest Octopus product for your usage and the annual saving versus your current tariff."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "days",
            "min": 7,
            "max": 90,
            "step": 1,
            "placeholder": {
              "en": "30"
            }
          }
        ],
        "tokens": [
          {
            "name": "best_product",
            "type": "string",
            "title": {
              "en": "Best product"
            },
            "example": {
              "en": "Agile"
            }
          },
          {
            "name": "annual_saving",
            "type": "number",
            "title": {
              "en": "Annual saving (£)"
            },
            "example": 120.5
          },
          {
            "name": "current_annual",
            "type": "number",
            "title": {
              "en": "Current annual cost (£)"
            },
            "example": 980
          },
          {
            "name": "best_annual",
            "type": "number",
            "title": {
              "en": "Best annual cost (£)"
            },
            "example": 859.5
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Electricity Meter",
        "nl": "Elektriciteitsmeter",
        "de": "Stromzähler",
        "fr": "Compteur d'électricité"
      },
      "class": "sensor",
      "capabilities": [
        "octopus_price",
        "octopus_price_level",
        "octopus_price_next",
        "octopus_smart_charge",
        "octopus_carbon",

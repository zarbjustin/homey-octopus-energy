{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "uk.co.zarb.octopusenergy",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#FF1493",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Octopus Energy"
  },
  "description": {
    "en": "Monitor your Octopus Energy tariffs, prices, usage and balance."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Justin Zarb",
    "email": "justin.zarb@zarb.co.uk"
  },
  "flow": {
    "triggers": [
      {
        "id": "balance_below",
        "title": {
          "en": "The account balance drops below ..."
        },
        "titleFormatted": {
          "en": "The balance of [[device]] drops below £[[amount]]"
        },
        "hint": {
          "en": "Triggers when your Octopus account balance falls below the amount."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          },
          {
            "type": "number",
            "name": "amount",
            "min": -10000,
            "max": 10000,
            "step": 1,
            "placeholder": {
              "en": "0"
            }
          }
        ],
        "tokens": [
          {
            "name": "balance",
            "type": "number",
            "title": {
              "en": "Balance (£)"
            },
            "example": -5.2
          }
        ]
      },
      {
        "id": "balance_changed",
        "title": {
          "en": "The account balance changed"
        },
        "titleFormatted": {
          "en": "The balance of [[device]] changed"
        },
        "hint": {
          "en": "Triggers when your Octopus account balance changes."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          }
        ],
        "tokens": [
          {
            "name": "balance",
            "type": "number",
            "title": {
              "en": "Balance (£)"
            },
            "example": 124.5
          }
        ]
      },
      {
        "id": "price_changed",
        "title": {
          "en": "The unit rate changed"
        },
        "hint": {
          "en": "Triggers each half hour when the electricity unit rate changes."
        },
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 18.5
          },
          {
            "name": "previous",
            "type": "number",
            "title": {
              "en": "Previous price"
            },
            "example": 22.1
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "price_below",
        "title": {
          "en": "The price drops below ..."
        },
        "titleFormatted": {
          "en": "The unit rate drops below [[price]] p/kWh"
        },
        "hint": {
          "en": "Triggers when a new half-hourly unit rate is below your threshold."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "price",
            "min": -50,
            "max": 200,
            "step": 0.1,
            "placeholder": {
              "en": "15"
            }
          }
        ],
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 12.3
          }
        ]
      },
      {
        "id": "price_plunge",
        "title": {
          "en": "The price went negative (plunge)"
        },
        "hint": {
          "en": "Triggers when the unit rate drops below zero — Octopus is paying you to use energy."
        },
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": -2.5
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "price_level_changed",
        "title": {
          "en": "The price level changed"
        },
        "hint": {
          "en": "Triggers when the price level changes between plunge, cheap, normal and expensive."
        },
        "tokens": [
          {
            "name": "level",
            "type": "string",
            "title": {
              "en": "Level"
            },
            "example": {
              "en": "cheap"
            }
          },
          {
            "name": "previous",
            "type": "string",
            "title": {
              "en": "Previous level"
            },
            "example": {
              "en": "normal"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "cheapest_slot_started",
        "title": {
          "en": "The cheapest half-hour started"
        },
        "titleFormatted": {
          "en": "Now is the cheapest half-hour in the next [[hours]] h"
        },
        "hint": {
          "en": "Triggers when the current half-hour is the cheapest within the look-ahead window."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "hours",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ],
        "tokens": [
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Price (p/kWh)"
            },
            "example": 9.8
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "balance_below_now",
        "title": {
          "en": "The account balance !{{is below|is not below}} ..."
        },
        "titleFormatted": {
          "en": "The balance of [[device]] !{{is below|is not below}} £[[amount]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=octopus_balance"
          },
          {
            "type": "number",
            "name": "amount",
            "min": -10000,
            "max": 10000,
            "step": 1,
            "placeholder": {
              "en": "0"
            }
          }
        ]
      },
      {
        "id": "price_below_now",
        "title": {
          "en": "Current price !{{is below|is not below}} ..."
        },
        "titleFormatted": {
          "en": "Current price !{{is below|is not below}} [[price]] p/kWh"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "price",
            "min": -50,
            "max": 200,
            "step": 0.1,
            "placeholder": {
              "en": "15"
            }
          }
        ]
      },
      {
        "id": "is_cheapest_now",
        "title": {
          "en": "Now !{{is|is not}} the cheapest half-hour"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} the cheapest half-hour in the next [[hours]] h"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "hours",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ]
      },
      {
        "id": "price_level_is",
        "title": {
          "en": "The price level !{{is|is not}} ..."
        },
        "titleFormatted": {
          "en": "The price level !{{is|is not}} [[level]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "dropdown",
            "name": "level",
            "values": [
              {
                "id": "plunge",
                "label": {
                  "en": "Plunge (negative)"
                }
              },
              {
                "id": "cheap",
                "label": {
                  "en": "Cheap"
                }
              },
              {
                "id": "normal",
                "label": {
                  "en": "Normal"
                }
              },
              {
                "id": "expensive",
                "label": {
                  "en": "Expensive"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "within_cheapest_period",
        "title": {
          "en": "Now !{{is|is not}} within the cheapest period"
        },
        "titleFormatted": {
          "en": "Now !{{is|is not}} within the cheapest [[duration]] h block of the next [[within]] h"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "number",
            "name": "within",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "refresh_now",
        "title": {
          "en": "Refresh Octopus data"
        },
        "hint": {
          "en": "Immediately refresh prices, usage and balance from Octopus Energy."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          }
        ]
      },
      {
        "id": "find_cheapest_slot",
        "title": {
          "en": "Find the cheapest upcoming slot"
        },
        "titleFormatted": {
          "en": "Find the cheapest [[duration]] h slot in the next [[within]] h"
        },
        "hint": {
          "en": "Returns the start time and average price of the cheapest block of half-hours ahead."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=electricity"
          },
          {
            "type": "number",
            "name": "duration",
            "min": 0.5,
            "max": 12,
            "step": 0.5,
            "placeholder": {
              "en": "3"
            }
          },
          {
            "type": "number",
            "name": "within",
            "min": 1,
            "max": 48,
            "step": 1,
            "placeholder": {
              "en": "12"
            }
          }
        ],
        "tokens": [
          {
            "name": "start_time",
            "type": "string",
            "title": {
              "en": "Start time"
            },
            "example": {
              "en": "Mon 01:30"
            }
          },
          {
            "name": "price",
            "type": "number",
            "title": {
              "en": "Average price (p/kWh)"
            },
            "example": 8.4
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Electricity Meter"
      },
      "class": "sensor",
      "capabilities": [
        "octopus_price",
        "octopus_price_level",
        "meter_power",
        "octopus_usage_today",
        "octopus_cost_today",
        "octopus_standing_charge",
        "octopus_balance"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "title": {
            "en": "Total consumption"
          }
        }
      },
      "energy": {
        "cumulative": true,
        "cumulativeImportedCapability": "meter_power"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "images": {
        "small": "/drivers/electricity/assets/images/small.png",
        "large": "/drivers/electricity/assets/images/large.png",
        "xlarge": "/drivers/electricity/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "start"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "start"
        }
      ],
      "settings": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Refresh interval (minutes)"
          },
          "value": 30,
          "min": 5,
          "max": 1440,
          "hint": {
            "en": "How often to refresh prices, usage and balance. Prices update once per half hour."
          }
        },
        {
          "id": "vat",
          "type": "dropdown",
          "label": {
            "en": "Prices include VAT"
          },
          "value": "inc",
          "hint": {
            "en": "Whether displayed unit rates and standing charges include 5% VAT."
          },
          "values": [
            {
              "id": "inc",
              "label": {
                "en": "Including VAT"
              }
            },
            {
              "id": "exc",
              "label": {
                "en": "Excluding VAT"
              }
            }
          ]
        },
        {
          "id": "cheap_threshold",
          "type": "number",
          "label": {
            "en": "\"Cheap\" price threshold (p/kWh)"
          },
          "value": 15,
          "min": -50,
          "max": 200,
          "hint": {
            "en": "At or below this unit rate the price level is considered cheap."
          }
        },
        {
          "id": "expensive_threshold",
          "type": "number",
          "label": {
            "en": "\"Expensive\" price threshold (p/kWh)"
          },
          "value": 30,
          "min": -50,
          "max": 200,
          "hint": {
            "en": "At or above this unit rate the price level is considered expensive."
          }
        },
        {
          "id": "live_power",
          "type": "checkbox",
          "label": {
            "en": "Live power (Octopus Home Mini)"
          },
          "value": false,
          "hint": {
            "en": "If you have an Octopus Home Mini, show near real-time power (W). Polls every 30 seconds."
          }
        }
      ],
      "id": "electricity"
    },
    {
      "name": {
        "en": "Gas Meter"
      },
      "class": "sensor",
      "capabilities": [
        "octopus_price",
        "meter_gas",
        "octopus_usage_today",
        "octopus_cost_today",
        "octopus_standing_charge",
        "octopus_balance"
      ],
      "capabilitiesOptions": {
        "meter_gas": {
          "title": {
            "en": "Total gas"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "images": {
        "small": "/drivers/gas/assets/images/small.png",
        "large": "/drivers/gas/assets/images/large.png",
        "xlarge": "/drivers/gas/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "start"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "start"
        }
      ],
      "settings": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Refresh interval (minutes)"
          },
          "value": 30,
          "min": 5,
          "max": 1440,
          "hint": {
            "en": "How often to refresh prices, usage and balance."
          }
        },
        {
          "id": "vat",
          "type": "dropdown",
          "label": {
            "en": "Prices include VAT"
          },
          "value": "inc",
          "values": [
            {
              "id": "inc",
              "label": {
                "en": "Including VAT"
              }
            },
            {
              "id": "exc",
              "label": {
                "en": "Excluding VAT"
              }
            }
          ]
        },
        {
          "id": "gas_units",
          "type": "dropdown",
          "label": {
            "en": "Meter reports consumption in"
          },
          "value": "m3",
          "hint": {
            "en": "Smart (SMETS2) gas meters usually report cubic metres; older meters may report kWh."
          },
          "values": [
            {
              "id": "m3",
              "label": {
                "en": "Cubic metres (m³)"
              }
            },
            {
              "id": "kwh",
              "label": {
                "en": "Kilowatt-hours (kWh)"
              }
            }
          ]
        },
        {
          "id": "gas_cv",
          "type": "number",
          "label": {
            "en": "m³ → kWh conversion factor"
          },
          "value": 11.1868,
          "min": 1,
          "max": 20,
          "decimals": 4,
          "hint": {
            "en": "Volume-to-energy factor from your bill (calorific value × 1.02264 ÷ 3.6). Typically ~11.19."
          }
        }
      ],
      "id": "gas"
    }
  ],
  "widgets": {
    "price": {
      "name": {
        "en": "Octopus Price"
      },
      "settings": [
        {
          "id": "device",
          "type": "device",
          "title": {
            "en": "Electricity meter"
          },
          "filter": "driver_id=electricity"
        }
      ],
      "height": 140,
      "api": {
        "getData": {
          "method": "GET",
          "path": "/"
        }
      },
      "id": "price"
    }
  },
  "capabilities": {
    "octopus_balance": {
      "type": "number",
      "title": {
        "en": "Account balance"
      },
      "units": {
        "en": "£"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/balance.svg",
      "insights": true
    },
    "octopus_cost_today": {
      "type": "number",
      "title": {
        "en": "Cost (last 24h)"
      },
      "units": {
        "en": "£"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/cost.svg",
      "insights": true
    },
    "octopus_price": {
      "type": "number",
      "title": {
        "en": "Current price"
      },
      "units": {
        "en": "p/kWh"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/price.svg",
      "insights": true,
      "insightsTitleTrue": {
        "en": "Price"
      }
    },
    "octopus_price_level": {
      "type": "enum",
      "title": {
        "en": "Price level"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/level.svg",
      "values": [
        {
          "id": "plunge",
          "title": {
            "en": "Plunge (negative)"
          }
        },
        {
          "id": "cheap",
          "title": {
            "en": "Cheap"
          }
        },
        {
          "id": "normal",
          "title": {
            "en": "Normal"
          }
        },
        {
          "id": "expensive",
          "title": {
            "en": "Expensive"
          }
        }
      ]
    },
    "octopus_standing_charge": {
      "type": "number",
      "title": {
        "en": "Standing charge"
      },
      "units": {
        "en": "p/day"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/standing.svg",
      "insights": true
    },
    "octopus_usage_today": {
      "type": "number",
      "title": {
        "en": "Usage (last 24h)"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/usage.svg",
      "insights": true
    }
  }
}